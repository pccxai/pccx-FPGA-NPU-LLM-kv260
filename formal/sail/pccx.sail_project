// pccx — Sail ISA model manifest.
//
// Ground truth: ../../hw/rtl/NPU_Controller/NPU_Control_Unit/ISA_PACKAGE/isa_pkg.sv
// Sail website:   https://sail-lang.org/
// pccx docs:      https://pccxai.github.io/pccx/en/docs/v002/ISA/
//
// Build:   sail --check  pccx.sail_project   (type-check only)
//          sail --help   pccx.sail_project   (list commands)
//
// The module layout mirrors the knowledge-base guidance
// ([types + registers] -> [decode] -> [execute]) so future extensions
// can be slotted into the right bucket without reshuffling.

prelude {
  files
    src/prelude.sail,
}

types {
  requires prelude
  files
    src/pccx_types.sail,
}

regs {
  requires prelude, types
  files
    src/pccx_regs.sail,
}

decode {
  requires prelude, types, regs
  files
    src/pccx_decode.sail,
}

execute {
  requires prelude, types, regs, decode
  files
    src/pccx_execute.sail,
}

test {
  requires prelude, types, regs, decode, execute
  files
    tests/smoke_decode.sail,
}
